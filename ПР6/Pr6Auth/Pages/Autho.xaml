<Page x:Class="Pr6Auth.Pages.Autho"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация" 
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="300">

            <TextBlock Text="Вход в систему" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="tbLogin" 
                     Height="30" 
                     Margin="0,5,0,10"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="pbPassword" 
                         Height="30" 
                         Margin="0,5,0,10"/>

            <!-- Капча (скрыта по умолчанию) -->
            <TextBlock x:Name="tblCaptcha" 
                       Text="Капча"
                       Visibility="Collapsed"
                       Margin="0,10,0,0"/>
            <TextBox x:Name="tbCaptcha" 
                     Height="30" 
                     Visibility="Collapsed"
                     Margin="0,5,0,10"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,0">
                <Button x:Name="btnGuest" 
                        Content="Гость" 
                        Click="BtnGuestClick"
                        Width="100"
                        Height="35"
                        Margin="5"/>
                <Button x:Name="btnRegister" 
                        Content="Регистрация" 
                        Click="BtnRegisterClick"
                        Width="100"
                        Height="35"
                        Margin="5"/>
                <Button x:Name="btnLogin" 
                        Content="Войти" 
                        Click="BtnLoginClick"
                        Width="100"
                        Height="35"
                        Margin="5"/>
            </StackPanel>

            <!-- Кнопка "Забыли пароль?" -->
            <Button x:Name="btnForgotPassword" 
                    Content="Забыли пароль?" 
                    Click="BtnForgotPasswordClick"
                    Width="150" 
                    Height="30" 
                    Margin="5"
                    HorizontalAlignment="Center"/>

            <!-- Поле для ввода кода 2FA (скрыто по умолчанию) -->
            <TextBlock x:Name="tbl2FACode" 
                       Text="Введите код из письма:" 
                       Visibility="Collapsed"
                       Margin="0,10,0,0"/>
            <TextBox x:Name="tb2FACode" 
                     Width="150" 
                     Height="30"
                     Visibility="Collapsed" 
                     Margin="5"/>
            <Button x:Name="btnConfirm2FA" 
                    Content="Подтвердить" 
                    Click="BtnConfirm2FAClick"
                    Width="120" 
                    Height="35"
                    Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>
<Page x:Class="Pr6Auth.Pages.ResetPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Смена пароля" 
      Background="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="300">

            <TextBlock Text="Смена пароля" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Новый пароль"/>
            <PasswordBox x:Name="pbNewPassword" 
                         Height="30" 
                         Margin="0,5,0,10"/>

            <TextBlock Text="Подтверждение пароля"/>
            <PasswordBox x:Name="pbConfirmPassword" 
                         Height="30" 
                         Margin="0,5,0,10"/>

            <Button Content="Сохранить" 
                    Click="SavePassword_Click" 
                    Width="120" 
                    Height="35" 
                    Margin="5"/>
            <Button Content="Отмена" 
                    Click="Cancel_Click" 
                    Width="120" 
                    Height="35" 
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
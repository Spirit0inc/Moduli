<Page x:Class="Pr6Auth.Pages.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация" 
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="300">

            <TextBlock Text="Регистрация нового пользователя" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="tbLogin" 
                     Height="30" 
                     Margin="0,5,0,10"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="pbPassword" 
                         Height="30" 
                         Margin="0,5,0,10"/>

            <TextBlock Text="Подтверждение пароля"/>
            <PasswordBox x:Name="pbConfirmPassword" 
                         Height="30" 
                         Margin="0,5,0,10"/>

            <TextBlock Text="Роль"/>
            <ComboBox x:Name="cbRole" 
                      Height="30" 
                      Margin="0,5,0,10"
                      SelectedIndex="0">
                <ComboBoxItem Content="Пользователь" Tag="user"/>
                <ComboBoxItem Content="Администратор" Tag="admin"/>
            </ComboBox>

            <TextBlock x:Name="tbError" 
                       Foreground="Red" 
                       FontSize="12"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20,0,0">
                <Button x:Name="btnRegister" 
                        Content="Зарегистрировать" 
                        Click="BtnRegisterClick"
                        Width="140"
                        Height="35"
                        Margin="5"/>
                <Button x:Name="btnCancel" 
                        Content="Отмена" 
                        Click="BtnCancelClick"
                        Width="100"
                        Height="35"
                        Margin="5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>